ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama roda localmente, sem chave necessária.
# Só altere se o servidor não estiver na porta padrão:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# (Opcional) Caminho para os modelos Python do ESBMC.
# O pipeline já inclui os stubs básicos (nondet_int, nondet_bool, etc.) em
